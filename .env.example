# =============================================================================
# Phish-Guard AI - environment configuration
# -----------------------------------------------------------------------------
# 1. Copy this file to ".env"  ->  cp .env.example .env   (Windows: copy .env.example .env)
# 2. Fill in the real values below.
# 3. NEVER commit the real ".env" file. It is already listed in .gitignore.
#
# The Streamlit web app (app.py) reads only the two values below from the
# environment; both are normally typed into the app sidebar instead.
# =============================================================================

# ---------------------------------------------------------------------------
# Groq (LLM backend)
# ---------------------------------------------------------------------------
# GROQ_API_KEY is normally typed into the app sidebar (BYOK). You may pre-fill
# it here for convenience. Get a free key (no credit card) at:
#   https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# Live Inbox Monitor secret
# ---------------------------------------------------------------------------
# IMAP_APP_PASSWORD is the 16-character Gmail App Password for the hardcoded
# sandbox inbox phishguardbgu@gmail.com. It is required only for the Live Inbox
# Monitor tab; the Manual Tester tab does not need it.
IMAP_APP_PASSWORD=your-16-char-gmail-app-password
